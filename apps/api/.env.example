PORT=3000
DATABASE_URL=postgresql://hub_user:hub_password@localhost:5432/hub_estudiantil
DB_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_RETRIES=20
DB_CONNECTION_RETRY_DELAY_MS=2000
VALKEY_URL=redis://localhost:6379
VALKEY_KEY_PREFIX=hub-estudiantil
VALKEY_DEFAULT_TTL_SECONDS=300
VALKEY_CONNECTION_RETRIES=20
VALKEY_CONNECTION_RETRY_DELAY_MS=2000
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# Origen del frontend (sin barra final). Tras Google OAuth se redirige aquí con #access_token=...
WEB_APP_ORIGIN=http://localhost:5173

# Google Cloud Console → Credenciales → ID de cliente OAuth
# URI de redirección autorizada debe coincidir EXACTAMENTE con esta URL:
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Solo correos de dominios autorizados pueden crear cuenta nueva con Google.
ALLOWED_INSTITUTIONAL_EMAIL_DOMAINS=ucn.cl,alumnos.ucn.cl,ce.ucn.cl

# Login con correo y contraseña: POST /api/auth/login
# Tras npm run db:seed, los usuarios *.demo@ucn.cl usan la contraseña demo1234 (seeds/003_demo_passwords.sql).

# En NODE_ENV=production, el token demo POST /auth/dev/token queda desactivado salvo:
# ENABLE_DEV_TOKEN_AUTH=true
