{
  "name": "hub-estudiantil-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "cache:check": "tsx src/cache/check.ts",
    "db:check": "tsx src/database/check.ts",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "tsx src/database/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "start": "node dist/server.js",
    "test": "node -e \"console.log('Pruebas pendientes de implementacion.');\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "redis": "^5.12.1"
  }
}
